{
  "name": "pwa-task-manager",
  "version": "1.0.0",
  "description": "PWA Task Manager application",
  "main": "index.js",
  "type": "module",
  "scripts": {
    "test": "node tests/run-tests.js",
    "test:ui": "cd ui-test-framework && npm test",
    "test:all": "npm test && npm run test:ui",
    "security-check": "npm audit --audit-level=high",
    "prepare": "husky",
    "build": "node scripts/build.js",
    "test:ontograde": "npm run test:ontograde:patterns && npm run test:ontograde:logic",
    "test:ontograde:patterns": "node examples/ontograde/test-pattern-violations.js",
    "test:ontograde:logic": "node examples/ontograde/test-logic-violations.js"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "dependencies": {
    "n3": "^2.0.0"
  }
}
